# i3status вҖ” Nerd Font еӣҫж ҮзүҲ
general {
    colors = true
    interval = 5
}

order += "wireless _first_"
order += "ethernet _first_"
order += "volume master"
order += "cpu_usage"
order += "memory"
order += "cpu_temperature 0"
order += "battery all"
order += "tztime local"

wireless _first_ {
    format_up = " пҮ«  %quality"
    format_down = " пҮ«  зҰ»зәҝ"
}

ethernet _first_ {
    format_up = " пӣҝ  %ip"
    format_down = ""
}

volume master {
    format = " пҖЁ  %volume"
    format_muted = " пҖҰ  "
    device = "pulse"
    mixer = "Master"
}

cpu_usage {
    format = " пӢӣ  %usage"
}

memory {
    format = " пҮҖ  %used"
}

cpu_temperature 0 {
    format = " пӢү  %degreesВ°C"
}

battery all {
    format = " у°Ғ№  %percentage"
    # еҸҢз”өжұ  ThinkPadпјҡlast_full_capacity и®©з®—жі•еҢ№й…Қ upower зҡ„ DisplayDevice
    last_full_capacity = true
}

tztime local {
    format = " пҖ—  %m-%d %H:%M"
}